# Copy this file to .env and fill in your real values.
# This file is a TEMPLATE and is safe to commit. Never put real secrets here.

# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# The "from" address. Must be on a domain you've verified in Resend.
SENDER_EMAIL=noreply@alnaser-company.com

# Where contact-form submissions are delivered.
OWNER_EMAIL=fromwebsite@alnaser-company.com
